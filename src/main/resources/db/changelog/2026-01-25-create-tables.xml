<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.4.xsd">

    <changeSet id="create-user-horoscope" author="vova">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="user_horoscope" />
            </not>
        </preConditions>
        <createTable tableName="user_horoscope">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" />
            </column>
            <column name="user_id" type="BIGINT" />
            <column name="date" type="VARCHAR(100)" />
            <column name="horoscope" type="TEXT" />
            <column name="photo_path" type="VARCHAR(100)" />
        </createTable>
    </changeSet>

    <changeSet id="create-user-settings" author="vova">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="user_settings" />
            </not>
        </preConditions>
        <createTable tableName="user_settings">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" />
            </column>
            <column name="user_id" type="BIGINT" />
            <column name="pepe" type="VARCHAR(10)" />
        </createTable>
    </changeSet>

    <changeSet id="create-user-event-1" author="vova">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="user_event" />
            </not>
        </preConditions>
        <createTable tableName="user_event">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" />
            </column>
            <column name="user_id" type="BIGINT" />
            <column name="chat_id" type="BIGINT" />
            <column name="user_name" type="VARCHAR(255)" />
            <column name="chat_name" type="VARCHAR(255)" />
            <column name="inner_id" type="VARCHAR(255)" />
            <column name="timestamp" type="TIMESTAMP" />
            <column name="message_length" type="INTEGER" />
            <column name="type" type="VARCHAR(255)" />
            <column name="inner_type" type="VARCHAR(255)" />
        </createTable>
    </changeSet>

    <changeSet id="alter-user-settings" author="vova">
        <addColumn tableName="user_settings">
            <column name="text_case" type="VARCHAR(100)" />
            <column name="punctuation" type="VARCHAR(100)" />
        </addColumn>
    </changeSet>

    <changeSet id="alter-user-settings-1" author="vova">
        <dropColumn tableName="user_settings" columnName="pepe" />
        <addColumn tableName="user_settings">
            <column name="pepe" type="VARCHAR(100)" />
        </addColumn>
    </changeSet>

    <changeSet id="create-user-surprise-5" author="vova">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="user_surprise" />
            </not>
        </preConditions>
        <createTable tableName="user_surprise">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" />
            </column>
            <column name="user_from_id" type="BIGINT" />
            <column name="user_from_name" type="VARCHAR(255)" />
            <column name="user_to_id" type="BIGINT" />
            <column name="user_to_name" type="VARCHAR(255)" />
            <column name="message" type="TEXT" />
            <column name="message_id" type="INTEGER" />
            <column name="reverse_message_id" type="INTEGER" />
            <column name="sent" type="INTEGER" defaultValue="0" />
            <column name="can_reply" type="INTEGER" />
        </createTable>
    </changeSet>

    <changeSet id="create-user-ban-5" author="vova">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="user_ban" />
            </not>
        </preConditions>
        <createTable tableName="user_ban">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" />
            </column>
            <column name="user_id" type="BIGINT" />
            <column name="user_name" type="VARCHAR(255)" />
        </createTable>
    </changeSet>

    <changeSet id="create-mass-message" author="vova">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="mass_message" />
            </not>
        </preConditions>
        <createTable tableName="mass_message">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" />
            </column>
            <column name="user_id" type="BIGINT" />
            <column name="user_name" type="VARCHAR(255)" />
            <column name="message" type="TEXT" />
            <column name="timestamp" type="TIMESTAMP" />
            <column name="sent" type="INTEGER" />
        </createTable>
    </changeSet>
</databaseChangeLog>